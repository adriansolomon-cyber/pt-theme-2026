# ── Project Timber theme repo ─────────────────────────────
# Repo root IS the theme (deploys to wp-content/themes/pt-new-wp-theme-2026/).
# Keep only what belongs in the shipped theme; exclude everything else.

# macOS cruft
.DS_Store
._*
.Spotlight-V100
.Trashes

# Editor / tooling
.vscode/
.idea/
*.swp
*.log

# Node (if a build step is added later)
node_modules/
npm-debug.log*

# ── Not part of the shipped theme ─────────────────────────
# Migration source files + the custom mu-plugin. The mu-plugin
# (timber-product-config.php) is deployed to wp-content/mu-plugins/
# by hand, NOT as part of the theme — see notes.
scripts-to-migrate/

# Reference copy of the current live theme (parent to copy functionality FROM).
# Read-only reference — never shipped in the 2026 theme.
reference-theme/
old-theme-template/
